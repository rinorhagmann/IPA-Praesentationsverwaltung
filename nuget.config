<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Override any machine-wide feeds (e.g. authenticated Telerik) so the
       solution restores solely from the public NuGet gallery. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
