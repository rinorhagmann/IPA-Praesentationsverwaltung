# Copy this file to ".env" and fill in your SMTP credentials, then run
# `docker compose up`. The .env file is gitignored and is NOT baked into the
# image (values are passed to the container at runtime).
#
# When SMTP_HOST is left empty, the application uses the development file sender
# (e-mails are only logged / written to an outbox) instead of sending for real.

# --- Example: Gmail SMTP ---------------------------------------------------
# A Gmail "App Password" is required (normal account passwords do not work).
# Create one at https://myaccount.google.com/apppasswords
# For Gmail, SMTP_FROM must be the same address as SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your.address@gmail.com
SMTP_FROM_NAME=Wirtschaftsgymnasium Basel
