# ==========================================
# Standard .gitignore für .NET / Visual Studio
# Speziell optimiert für die IPA-Präsentationsverwaltung
# ==========================================

# --- Visual Studio Build- und Ausgabedateien ---
.vs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.sln.docstates

# --- JetBrains Rider / Resharper ---
.idea/
*.sln.iml

# --- Visual Studio Code ---
.vscode/

# --- .NET Core / ASP.NET Core Verzeichnisse ---
project.lock.json
project.fragment.lock.json
artifacts/
publish/
*.publishsettings

# --- Lokale Konfigurationen & Secrets (WICHTIG FÜR DATENSCHUTZ/SECURITY) ---
# Verhindert, dass Passwörter und DB-Verbindungsstrings auf GitHub landen
appsettings.Development.json
appsettings.Local.json
secrets.json
.microsoft.visualstudio.secrets.json

# --- Lokale Datenbankdateien (SQL Server LocalDB / Express) ---
*.mdf
*.ldf
*.sdf

# --- Frontend-Pakete (falls später npm/Bower für Bootstrap genutzt wird) ---
node_modules/
jspm_packages/
bower_components/

# --- Betriebssystem-Dateien ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Laufzeit-Daten (z. B. abgelegte Entwicklungs-E-Mails) ---
**/App_Data/

temp/