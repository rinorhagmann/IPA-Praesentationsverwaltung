@using IPA_Praesentationsverwaltung.Infrastructure
@model IReadOnlyList<Admin>
@{
    ViewData["Title"] = "Admin-Logins";
    ViewData["ActiveNav"] = "Admins";
    Layout = "_AdminLayout";
    int? currentUserId = User.GetUserId();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Admin-Logins</h1>
    <a class="btn btn-wgbs-dark" asp-controller="Admin" asp-action="CreateAdmin">Neuer Login</a>
</div>

<div class="table-card">
    <table class="table align-middle m-0 table-stack">
        <thead>
            <tr>
                <th>Name</th>
                <th>E-Mail</th>
                <th class="text-end">Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var admin in Model)
            {
                bool isCurrentUser = currentUserId == admin.Id;
                <tr>
                    <td data-label="Name">@admin.GetFullName()</td>
                    <td data-label="E-Mail">@admin.Email</td>
                    <td class="text-end cell-actions">
                        <div class="row-actions">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Admin" asp-action="EditAdmin" asp-route-id="@admin.Id">Bearbeiten</a>
                            @if (isCurrentUser)
                            {
                                <button type="button" class="btn btn-sm btn-wgbs-danger" disabled
                                        title="Sie können Ihren eigenen Login nicht löschen.">Löschen</button>
                            }
                            else
                            {
                                <form asp-controller="Admin" asp-action="DeleteAdmin" asp-route-id="@admin.Id" method="post"
                                      onsubmit="return confirm('Diesen Login löschen?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-wgbs-danger">Löschen</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
