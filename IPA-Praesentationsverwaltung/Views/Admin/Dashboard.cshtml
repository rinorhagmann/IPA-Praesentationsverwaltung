@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveNav"] = "Dashboard";
    Layout = "_AdminLayout";
}

<h1>Administrations-Dashboard</h1>

<div class="stat-grid">
    <div class="stat-card">
        <div>
            <div class="stat-label">Schüler insgesamt</div>
            <div class="stat-value">@Model.TotalStudents</div>
        </div>
        <div class="stat-icon">👥</div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Präsentationen</div>
            <div class="stat-value">@Model.TotalPresentations</div>
        </div>
        <div class="stat-icon">📄</div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Schüler ohne Eintragung</div>
            <div class="stat-value">@Model.StudentsWithoutRegistration</div>
        </div>
        <div class="stat-icon">⚠</div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Präsentationen ohne Zuseher</div>
            <div class="stat-value">@Model.PresentationsWithoutObservers</div>
        </div>
        <div class="stat-icon">👁</div>
    </div>
</div>
