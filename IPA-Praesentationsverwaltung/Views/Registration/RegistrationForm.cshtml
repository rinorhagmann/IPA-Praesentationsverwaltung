@model RegistrationFormViewModel
@{
    ViewData["Title"] = Model.IsEdit ? "Eintragung bearbeiten" : "Eintragung erstellen";
    ViewData["ActiveNav"] = "Registrations";
    Layout = "_AdminLayout";
}

<h1>@ViewData["Title"]</h1>

<div class="wgbs-card" style="max-width: 560px;">
    <form asp-controller="Registration" asp-action="@(Model.IsEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <div class="mb-3">
            <label asp-for="StudentId" class="form-label"></label>
            <select asp-for="StudentId" asp-items="Model.StudentOptions" class="form-select">
                <option value="">– bitte wählen –</option>
            </select>
            <span asp-validation-for="StudentId" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PresentationId" class="form-label"></label>
            <select asp-for="PresentationId" asp-items="Model.PresentationOptions" class="form-select">
                <option value="">– bitte wählen –</option>
            </select>
            <span asp-validation-for="PresentationId" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-wgbs-dark">Speichern</button>
        <a class="btn btn-outline-secondary" asp-controller="Registration" asp-action="Index">Abbrechen</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
