@model IReadOnlyList<Registration>
@{
    ViewData["Title"] = "Eintragungen verwalten";
    ViewData["ActiveNav"] = "Registrations";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Eintragungen</h1>
    <a class="btn btn-wgbs-dark" asp-controller="Registration" asp-action="Create">Neue Eintragung</a>
</div>

<div class="table-card">
    <table class="table align-middle m-0">
        <thead>
            <tr>
                <th>Schüler/in</th>
                <th>Präsentation</th>
                <th>Datum / Uhrzeit</th>
                <th>Eingetragen am</th>
                <th class="text-end">Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@(r.Student?.GetFullName())</td>
                    <td>@(r.Presentation?.Topic)</td>
                    <td>@(r.Presentation?.StartsAt.ToString("dd.MM.yyyy HH:mm")) Uhr</td>
                    <td>@r.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Registration" asp-action="Edit" asp-route-id="@r.Id">Bearbeiten</a>
                        <form asp-controller="Registration" asp-action="Delete" asp-route-id="@r.Id" method="post"
                              class="d-inline" onsubmit="return confirm('Diese Eintragung löschen?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-wgbs-danger">Löschen</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
