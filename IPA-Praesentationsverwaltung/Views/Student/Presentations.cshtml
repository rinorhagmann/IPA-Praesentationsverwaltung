@model StudentSelectionViewModel
@{
    ViewData["Title"] = "Präsentationen";
    ViewData["ActiveNav"] = "Presentations";
    Layout = "_StudentLayout";
}

<h1>Präsentationen</h1>
@if (Model.IsSelectionConfirmed)
{
    <p class="text-muted">Ihre Auswahl wurde bereits bestätigt und kann nicht mehr geändert werden.</p>
}
else if (Model.HasCompletedSelection)
{
    <p class="text-muted">Sie haben Ihre Auswahl bereits abgeschlossen. Sie können sie unter „Meine Auswahl" überprüfen und bestätigen.</p>
}
else
{
    <p class="text-muted">
        Bitte wählen Sie @Student.RequiredSelectionCount Präsentationen aus –
        noch @Model.RemainingSelections offen.
    </p>
}

@if (Model.AvailablePresentations.Count == 0)
{
    <div class="wgbs-card">Zurzeit sind keine Präsentationen verfügbar.</div>
}

@foreach (var item in Model.AvailablePresentations)
{
    <div class="presentation-row">
        <div class="col-field">
            <div class="label">Thema</div>
            <div class="value">@item.Topic</div>
        </div>
        <div class="col-field">
            <div class="label">Datum</div>
            <div class="value">@item.StartsAt.ToString("dd.MM.yyyy")</div>
        </div>
        <div class="col-field">
            <div class="label">Uhrzeit</div>
            <div class="value">@item.StartsAt.ToString("HH:mm") Uhr</div>
        </div>
        <div class="col-field">
            <div class="label">Raum</div>
            <div class="value">@item.RoomName</div>
        </div>
        <div class="col-field">
            <div class="label">Freie Plätze</div>
            <div class="value">@item.FreeSeats von @item.MaxObservers Plätzen</div>
        </div>
        <div class="col-field">
            @if (item.IsSelectedByStudent)
            {
                <span class="badge-status badge-selected">✓ AUSGEWÄHLT</span>
            }
            else if (item.HasFreeSeats)
            {
                <span class="badge-status badge-free">✓ FREI</span>
            }
            else
            {
                <span class="badge-status badge-full">✕ VOLL</span>
            }
        </div>
        <div class="col-action">
            @if (item.IsSelectedByStudent)
            {
                <button class="btn btn-wgbs-dark disabled" disabled>Ausgewählt</button>
            }
            else if (Model.IsSelectionConfirmed || Model.HasCompletedSelection || !item.HasFreeSeats)
            {
                <button class="btn btn-wgbs-dark disabled" disabled>Auswählen</button>
            }
            else
            {
                <form asp-controller="Student" asp-action="Select" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="presentationId" value="@item.Id" />
                    <button type="submit" class="btn btn-wgbs-dark">Auswählen</button>
                </form>
            }
        </div>
    </div>
}

@if (Model.HasCompletedSelection && !Model.IsSelectionConfirmed)
{
    <div class="text-center mt-3">
        <a class="btn btn-wgbs-dark" asp-controller="Student" asp-action="Confirm">Auswahl bestätigen</a>
    </div>
}
