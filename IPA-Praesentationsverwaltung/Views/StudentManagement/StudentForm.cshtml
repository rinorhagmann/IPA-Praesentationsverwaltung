@model StudentFormViewModel
@{
    ViewData["Title"] = Model.IsEdit ? "Schüler/in bearbeiten" : "Schüler/in erstellen";
    ViewData["ActiveNav"] = "Students";
    Layout = "_AdminLayout";
}

<h1>@ViewData["Title"]</h1>

<div class="wgbs-card" style="max-width: 520px;">
    <form asp-controller="StudentManagement" asp-action="@(Model.IsEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <div class="mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="new-password" />
            <div class="form-text">
                @(Model.IsEdit
                    ? "Leer lassen, um das aktuelle Passwort beizubehalten."
                    : "Leer lassen, um automatisch ein Initialpasswort zu erzeugen.")
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-wgbs-dark">Speichern</button>
        <a class="btn btn-outline-secondary" asp-controller="StudentManagement" asp-action="Index">Abbrechen</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
